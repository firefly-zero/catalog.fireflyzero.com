{% extends "base.html.j2" %}
{% block body %}
  <header class="text-center">
    <h1>
      <a href="https://fireflyzero.com" target="_blank">Firefly Zero</a>
      catalog
    </h1>
    <a href="./random.html" class="btn btn-primary">
      <i class="fa-solid fa-shuffle"></i>
      random
    </a>
    <a href="./authors.html" class="btn btn-primary">
      <i class="fa-solid fa-users"></i>
      authors
    </a>
    <a href="./@sys.html" class="btn btn-primary">
      <i class="fa-solid fa-gear"></i>
      system apps
    </a>
    <a
      href="https://github.com/firefly-zero/catalog.fireflyzero.com?tab=readme-ov-file#add-a-new-app"
      target="_blank"
      class="btn btn-primary"
    >
      <i class="fa-solid fa-plus"></i>
      add
    </a>
  </header>

  <main class="row row-cols-1 row-cols-md-4 g-1 mt-1">
    <h2 class="col col-md-12">Best</h2>
    {% for app in apps %}
      {% if app.visible and app.badge %}
        {% include 'app-card.html.j2' %}
      {% endif %}
    {% endfor %}
    <h2 class="col col-md-12">Rest</h2>
    {% for app in apps %}
      {% if app.visible and not app.badge %}
        {% include 'app-card.html.j2' %}
      {% endif %}
    {% endfor %}
  </main>
{% endblock %}
