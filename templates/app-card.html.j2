<div class="col col-md-4">
  <article class="card h-100">
    {% if app.splash %}
      <img src="{{ app.splash }}" class="card-img-top splash"/>
    {% endif %}
    <div class="card-body">
      {% if app.badge %}
        <span class="badge text-bg-dark">
          <i class="{{ app.badge.icon }}"></i>
          {{ app.badge.text }}
        </span>
      {% endif %}
      <h5 class="card-title">
        {% if app.icon %}
          <i class="{{ app.icon }}"></i>
        {% endif %}
        {{ app.name }}
        <br/>
        <span class="fs-6">
          by <a href="@{{ app.author.id }}.html">{{ app.author.name }}</a>
        </span>
      </h5>
      <p class="card-text">{{ app.short }}</p>
      <a href="./{{ app.id }}.html" class="btn btn-light">
        <i class="fa-solid fa-circle-info"></i>
        info
      </a>
      <a
        href="{{ app.download }}"
        {% if app.direct %}download{% else %}target="_blank"{% endif %}
        class="btn btn-light"
      >
        <i class="fa-solid fa-download"></i>
        get
      </a>
    </div>
  </article>
</div>
